# WebDev Software Catalog — variables de entorno
# Copia este archivo a .env y completa los valores.
# NUNCA subas el archivo .env a control de versiones.

# ── Obligatorio para reportes con IA ──────────────────────────────────────────
# Clave de API de Anthropic. Obtén la tuya en https://console.anthropic.com
# Si se define aquí, tiene precedencia sobre el campo "api_key" de config.json.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Autenticación de la interfaz web (opcional) ────────────────────────────────
# Si se define, todas las rutas /api/* exigen el token en el encabezado
# Authorization: Bearer <token>  o  X-Auth-Token: <token>
# Genera uno con: python -c "import secrets; print(secrets.token_hex(32))"
# Déjalo vacío (o sin definir) para acceso local sin autenticación.
WEBDEV_AUTH_TOKEN=

# ── Proxy de red (opcional) ───────────────────────────────────────────────────
# Alternativa a configurarlo desde la interfaz (se guarda en config.json).
# Acepta http://, https://, socks4://, socks5://
# HTTPS_PROXY=http://proxy.corporativo.cl:8080
# HTTP_PROXY=http://proxy.corporativo.cl:8080

# ── Límites de recursos (opcional) ───────────────────────────────────────────
# Tamaño máximo de respuesta JSON de APIs externas (bytes). Por defecto 8 MB.
# WEBDEV_MAX_JSON_BYTES=8388608

# Número máximo de dependencias por auditoría. Por defecto 2000.
# WEBDEV_MAX_DEPS=2000

# Tamaño máximo del archivo subido para auditoría/codescan (bytes). Por defecto 2 MB.
# WEBDEV_MAX_UPLOAD_BYTES=2097152

# Hilos paralelos para auditorías. Por defecto 8.
# WEBDEV_MAX_WORKERS=8
